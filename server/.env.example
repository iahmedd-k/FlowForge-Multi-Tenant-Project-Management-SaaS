# Backend Environment Variables - Production on Render
# These should be set in Render.com dashboard under Environment Variables

PORT=5000

# MongoDB
MONGO_URI=your_mongodb_connection_string

# JWT Secrets (use strong random strings)
JWT_ACCESS_SECRET=your_super_secret_access_key_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS: Your Vercel frontend URL
CLIENT_URL=https://flowforge-git-main-ahmed-khans-projects-56556017.vercel.app

# Environment
NODE_ENV=production
SKIP_STRIPE=false

# Email Service (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password

# Stripe API Keys (from Stripe Dashboard)
STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_PRO_PRICE_ID=price_your_pro_id
STRIPE_BUSINESS_PRICE_ID=price_your_business_id

# Invite Token
INVITE_TOKEN_SECRET=another_random_secret_string

# Cloudinary (Image upload)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Groq API (AI)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant

# Google OAuth (Get from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
